<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <item android:drawable="@drawable/splash_gradient"/>

    <!-- Outer glow -->
    <item
        android:gravity="center"
        android:width="170dp"
        android:height="170dp">

        <shape android:shape="oval">
            <solid android:color="#08FFFFFF"/>
        </shape>

    </item>

    <!-- Middle glow -->
    <item
        android:gravity="center"
        android:width="135dp"
        android:height="135dp">

        <shape android:shape="oval">
            <solid android:color="#10FFFFFF"/>
        </shape>

    </item>

    <!-- Inner circle -->
    <item
        android:gravity="center"
        android:width="105dp"
        android:height="105dp">

        <shape android:shape="oval">
            <solid android:color="#18FFFFFF"/>

            <stroke
                android:width="1dp"
                android:color="#30FFFFFF"/>
        </shape>

    </item>

    <!-- Logo -->
    <item
        android:gravity="center"
        android:width="70dp"
        android:height="70dp"
        android:drawable="@mipmap/ic_launcher"/>

</layer-list>